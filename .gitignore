# ── 输出文件（保留文件夹，忽略内容）──────────────────────────────────────────
output/*
!output/.gitkeep

# ── robots 目录（保留文件夹，忽略内容）────────────────────────────────────────
robots/*
!robots/.gitkeep

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ── 虚拟环境 ──────────────────────────────────────────────────────────────────
.venv/
venv/
env/
.conda/

# ── 编辑器 / OS ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
